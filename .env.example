# Public app configuration
NEXT_PUBLIC_PORTFOLIO_CONTRACT=0xa077b0dea3bb122ed7e71ecdf7ae0d7475343e0b
NEXT_PUBLIC_SITE_URL=https://ritual-lilac.vercel.app

# Primary multichain portfolio indexer. Keep this server-side and secret.
ZERION_API_KEY=

# Optional secondary multichain indexer.
DEBANK_ACCESS_KEY=

# Optional normalized provider override. {address} is replaced at request time.
PORTFOLIO_API_URL_TEMPLATE=https://api.example.com/portfolio?address={address}
PORTFOLIO_API_KEY=

# Ritual contract tooling (never commit a real private key)
RITUAL_RPC_URL=https://rpc.ritualfoundation.org
PRIVATE_KEY=
PORTFOLIO_API_BASE_URL=https://eth.blockscout.com/api/v2/addresses/
PORTFOLIO_API_URL_SUFFIX=/token-balances
